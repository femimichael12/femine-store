rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- REUSABLE FUNCTIONS ---
    
    // Check if the user is logged in
    function isSignedIn() {
      return request.auth != null;
    }

    // Check if the user is the owner of the document (UID matches)
    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    // Check if the user has an admin role in the 'users' collection
    function isAdmin() {
      return isSignedIn() && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // --- COLLECTION RULES ---

    // Products: Publicly readable, but only admins can modify
    match /products/{productId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // User Profiles: Users can manage their own, Admins can see/manage all
    match /users/{userId} {
      allow read, write: if isOwner(userId) || isAdmin();
    }

    // Orders: 
    // - Authenticated users can create orders linked to their UID
    // - Users can read only their own orders
    // - Admins can manage all orders
    match /orders/{orderId} {
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow update, delete: if isAdmin();
    }
    
    // Default deny for all other collections
    match /{document=**} {
      allow read, write: if isAdmin();
    }
  }
}